# Copy to .env — never commit .env to source control

# ── Local PostgreSQL ──────────────────────────────────────────────────────────
DB_NAME=awslensdb
DB_USER=postgres
DB_PASSWORD=postgres

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=replace-with-a-long-random-string

# ── AWS (production) ──────────────────────────────────────────────────────────
# When DB_SECRET_NAME is set, DB_USER / DB_PASSWORD above are ignored.
# DB_SECRET_NAME=prod/awslens/db
# AWS_REGION=us-east-1
